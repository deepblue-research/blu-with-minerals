# Google Cloud Console - OAuth 2.0 Client ID
# Create this in Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Backend API Base URL
# If running locally with the provided backend, use http://localhost:8080/api
# In production, use your deployed backend URL
VITE_API_BASE_URL="http://localhost:8080/api"

# Optional: Default currency for the UI (overridden by backend settings)
VITE_DEFAULT_CURRENCY="INR"
