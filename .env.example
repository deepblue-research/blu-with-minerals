# Backend Environment Variables
PORT=8080
DATABASE_URL="postgresql://user:password@localhost:5432/invoice_db"

# Google OAuth Configuration
# Obtain these from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Authentication Security
# Used to sign the session JWTs issued by the backend
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Domain Restriction
# Only emails ending with this domain will be allowed to sign in
ALLOWED_EMAIL_DOMAIN="aspecificdomain.in"

# Automation Security
# Secret key that must be passed in the 'x-cron-key' header for the recurring trigger
CRON_SECRET="your-secure-cron-token"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Invoices <your-email@gmail.com>"

# Storage (Google Cloud Storage)
GCS_BUCKET_NAME="your-invoice-pdfs-bucket"
GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account-key.json"

# Frontend Environment Variables (Vite)
# Note: These must be prefixed with VITE_ to be accessible in the frontend code
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_API_BASE_URL="http://localhost:8080/api"
