{
  "name": "invoice-backend",
  "version": "1.0.0",
  "description": "Backend service for generating and sending invoices",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && npm run copy-templates",
    "copy-templates": "node -e \"const fs = require('fs'); const path = require('path'); const s = 'src/templates'; const d = 'dist/templates'; if (fs.existsSync(s)) { fs.mkdirSync(d, { recursive: true }); fs.readdirSync(s).forEach(f => { if (f.endsWith('.hbs')) fs.copyFileSync(path.join(s, f), path.join(d, f)) }) }\"",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "invoice",
    "generator",
    "puppeteer",
    "express",
    "prisma"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.1",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "8.11.11",
    "prisma": "^7.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
