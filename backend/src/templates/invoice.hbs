</head>
<body class="bg-white text-gray-900">
    <div class="max-w-3xl mx-auto px-16 py-14">

        <!-- ── Header: Company (left) + Invoice Meta (right) ── -->
        <div class="flex justify-between items-start pb-10 border-b border-gray-100 mb-10">

            <!-- Company Info -->
            <div>
                {{#if company.logoUrl}}
                <img src="{{company.logoUrl}}" alt="{{company.name}}" class="h-10 object-contain mb-3">
                {{/if}}
                <p class="text-[10px] font-bold tracking-widest uppercase text-gray-800 mb-1">{{company.name}}</p>
                <div class="text-[11px] text-gray-400 leading-relaxed whitespace-pre-line max-w-[220px]">{{company.address}}</div>
                {{#if company.taxId}}
                <p class="text-[10px] text-gray-400 font-medium mt-1 uppercase tracking-wide">Tax ID: {{company.taxId}}</p>
                {{/if}}
            </div>

            <!-- Invoice Number + Dates -->
            <div class="text-right">
                <p class="text-[10px] font-bold tracking-widest uppercase text-gray-300 mb-2">Invoice</p>
                <p class="font-mono-custom text-xl font-medium text-gray-800 tracking-tight mb-4">{{invoiceNumber}}</p>
                <div class="space-y-1.5">
                    <div class="flex items-baseline justify-end gap-3 text-[12px]">
                        <span class="text-gray-400 font-medium">Issued</span>
                        <span class="text-gray-600 font-medium">{{issueDate}}</span>
                    </div>
                    <div class="flex items-baseline justify-end gap-3 text-[12px]">
                        <span class="text-gray-400 font-medium">Due</span>
                        <span class="text-gray-600 font-medium">{{dueDate}}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Bill To + Decorative Title ── -->
        <div class="flex justify-between items-end mb-10 pb-10 border-b border-gray-100">

            <!-- Client Info -->
            <div>
                <p class="text-[10px] font-bold tracking-widest uppercase text-gray-300 mb-3">Bill To</p>
                <p class="text-[15px] font-semibold text-gray-900 mb-1">{{client.name}}</p>
                <p class="text-[12px] text-gray-400 whitespace-pre-line leading-relaxed max-w-xs">{{client.address}}</p>
                {{#if client.taxId}}
                <p class="text-[10px] text-gray-300 mt-2 tracking-wide">Tax ID: {{client.taxId}}</p>
                {{/if}}
            </div>

            <!-- Decorative "Invoice" watermark word -->
            <div class="text-right select-none">
                <p class="text-5xl font-light tracking-tight text-gray-100 leading-none">Invoice</p>
            </div>
        </div>

        <!-- ── Items Table ── -->
        <div class="mb-10">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200">
                        <th class="pb-3 text-left text-[10px] font-bold tracking-widest uppercase text-gray-300">Description</th>
                        <th class="pb-3 text-center text-[10px] font-bold tracking-widest uppercase text-gray-300 w-20">Qty</th>
                        <th class="pb-3 text-right text-[10px] font-bold tracking-widest uppercase text-gray-300 w-32">Unit Price</th>
                        <th class="pb-3 text-right text-[10px] font-bold tracking-widest uppercase text-gray-300 w-32">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr class="border-b border-gray-50">
                        <td class="py-5 align-top pr-6">
                            <p class="text-[13px] font-medium text-gray-800 leading-snug">{{this.description}}</p>
                        </td>
                        <td class="py-5 align-top text-[13px] text-gray-400 text-center">{{this.quantity}}</td>
                        <td class="py-5 align-top text-[13px] text-gray-400 text-right">{{this.unitPriceFormatted}}</td>
                        <td class="py-5 align-top text-[13px] font-semibold text-gray-800 text-right">{{this.totalFormatted}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <!-- ── Totals ── -->
        <div class="flex justify-end mb-14">
            <div class="w-60 space-y-2.5 pt-5 border-t border-gray-100">
                <div class="flex justify-between text-[13px]">
                    <span class="text-gray-400">Subtotal</span>
                    <span class="text-gray-700 font-medium">{{subtotalFormatted}}</span>
                </div>
                {{#if taxRate}}
                <div class="flex justify-between text-[13px]">
                    <span class="text-gray-400">Tax ({{taxRate}}%)</span>
                    <span class="text-gray-700 font-medium">{{taxAmountFormatted}}</span>
                </div>
                {{/if}}
                <div class="flex justify-between items-baseline pt-4 border-t border-gray-100">
                    <span class="text-[11px] font-bold uppercase tracking-widest text-gray-700">Total</span>
                    <span class="text-2xl font-light text-gray-900 tracking-tight">{{totalAmountFormatted}}</span>
                </div>
            </div>
        </div>

        <!-- ── Footer: Payment Info + Notes ── -->
        <div class="grid grid-cols-2 gap-16 pt-10 border-t border-gray-100">
            <div>
                <p class="text-[10px] font-bold tracking-widest uppercase text-gray-300 mb-3">Payment Information</p>
                <div class="text-[11px] text-gray-400 leading-relaxed whitespace-pre-line">{{company.bankDetails}}</div>
            </div>
            <div class="flex flex-col justify-between text-right">
                {{#if notes}}
                <div>
                    <p class="text-[10px] font-bold tracking-widest uppercase text-gray-300 mb-2">Notes</p>
                    <p class="text-[11px] text-gray-400 italic leading-relaxed">{{notes}}</p>
                </div>
                {{/if}}
                <p class="text-[10px] tracking-widest uppercase text-gray-200 mt-8">Thank you for your business</p>
            </div>
        </div>



    </div>
</body>
</html>
